{
  "name": "firealive-analyst-client",
  "version": "1.0.45",
  "description": "FireAlive SOC Analyst Wellbeing Platform \u2014 Analyst Client",
  "main": "main.js",
  "author": "Peter Mancina",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder --mac --win --linux"
  },
  "dependencies": {
    "@signalapp/libsignal-client": "^0.94.0",
    "pdfkit": "^0.18.0"
  },
  "devDependencies": {
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "esbuild": "0.27.7",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.firealive.analyst-client",
    "productName": "FireAlive Analyst Client",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "signal-e2ee.js",
      "abuse-seal.js",
      "preload.js",
      "index.html",
      "app.js",
      "assets/**/*"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist",
      "icon": "assets/icon.png"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "Office",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    },
    "icon": "assets/icon.png"
  }
}
