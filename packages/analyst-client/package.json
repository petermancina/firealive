{
  "name": "firealive-analyst-client",
  "version": "1.0.84",
  "description": "FireAlive SOC Analyst Wellbeing Platform \u2014 Analyst Client",
  "main": "main.js",
  "author": "Peter Mancina",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder --mac --win --linux"
  },
  "dependencies": {
    "@firealive/shared": "file:../shared",
    "@signalapp/libsignal-client": "^0.97.2",
    "node-llama-cpp": "^3.19.0",
    "pdfkit": "^0.19.1"
  },
  "devDependencies": {
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "esbuild": "0.28.1",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.firealive.analyst-client",
    "productName": "FireAlive Analyst Client",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "app.js",
      "kb-local.js",
      "local-llm.js",
      "model-utility.js",
      "gguf-validate.js",
      "local-malware-scan.js",
      "assets/**/*"
    ],
    "asarUnpack": [
      "node_modules/node-llama-cpp/**",
      "node_modules/@node-llama-cpp/**"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist",
      "icon": "assets/icon.png"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "Office",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true
    },
    "icon": "assets/icon.png"
  }
}
