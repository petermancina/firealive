{
  "name": "firealive-global-dashboard",
  "version": "1.0.52",
  "description": "FireAlive \u2014 Global CISO Dashboard",
  "main": "main.js",
  "author": "Peter Mancina",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "esbuild": "0.27.7",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.firealive.global-dashboard",
    "productName": "FireAlive Global Dashboard",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "app.js"
    ],
    "extraResources": [
      {
        "from": "../global-dashboard-server",
        "to": "gd-server"
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "icon": "assets/icon.png"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png"
    },
    "icon": "assets/icon.png"
  }
}
