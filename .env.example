# ═══════════════════════════════════════════════════════════════════════════════
# FireAlive — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
#
# Copy this file to `.env` in the same directory and fill in real values.
# `.env` is gitignored. NEVER commit a populated .env file.
#
# Key generation: any var documented below as "32 bytes hex" can be generated
# with:
#
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# All keys generated this way are cryptographically secure. Generate distinct
# values for each KEK / secret -- do NOT reuse the same key across roles.
#
# Sections:
#   1. Required for any production deployment
#   2. Server / runtime
#   3. Database + backup paths
#   4. Backup scheduling and retention
#   5. CORS + cross-origin client allow-lists
#   6. Logging
#   7. SIEM streaming (optional)
#   8. SMTP (optional, for email notifications)
#   9. Local LLM (optional, for AI-assisted features)
#  10. OODA scheduled mode (optional)
#  11. HashiCorp Vault (optional, only if using Vault key-wrapping provider)
#  12. Diagnostic / advanced (use with care)
#
# ═══════════════════════════════════════════════════════════════════════════════
# 1. REQUIRED FOR ANY PRODUCTION DEPLOYMENT
# ═══════════════════════════════════════════════════════════════════════════════
#
# These four secrets MUST be set to real values before running in production.
# The server will START with insecure defaults if these are missing, but key
# operations (auth, encryption, audit-log integrity) will be trivially
# bypassable. Refuse to deploy without them.

# JWT_SECRET — signing key for authentication tokens.
# Used by middleware/auth.js to sign and verify the JWT bearer tokens that
# carry user identity across requests. If unset, defaults to
# 'CHANGE_ME_INSECURE_DEFAULT' which makes every JWT trivially forgeable.
# Generate: 32 bytes hex (see top-of-file note).
JWT_SECRET=CHANGE_ME_generate_32_bytes_hex

# TIER1_ENCRYPTION_KEY — primary KEK (Key Encryption Key) for backups,
# integration credentials, and signing keys. Wraps every backup's per-backup
# DEK; decrypts SMTP/SIEM/integration credentials at runtime; encrypts
# Ed25519 chain-signing private keys.
# If unset, integration credentials cannot be decrypted, backups cannot
# be wrapped, and the backup chain cannot be signed.
# Generate: 32 bytes hex.
# DO NOT ROTATE without re-wrapping affected ciphertexts -- old data
# encrypted under the old key becomes unrecoverable. Add a new kms_provider
# row for rotation rather than replacing this in place.
TIER1_ENCRYPTION_KEY=CHANGE_ME_generate_32_bytes_hex

# TIER3_ENCRYPTION_KEY — secondary KEK for high-sensitivity columns.
# Used by services/totp.js to encrypt users.totp_secret. A future commit
# will also use it for other Tier-3 PII.
# If unset, TOTP enrollment fails with ENCRYPTION_NOT_CONFIGURED, and the
# entire two-person restore-approval gate is unusable.
# Generate: 32 bytes hex. Distinct from TIER1_ENCRYPTION_KEY.
TIER3_ENCRYPTION_KEY=CHANGE_ME_generate_32_bytes_hex

# LOG_HMAC_KEY — HMAC signing key for audit-log row integrity.
# Each audit_log row carries an HMAC-SHA-256 over the row contents so
# that DB-level tampering of audit entries is detectable at compliance-
# scan time. If unset, falls back to TIER1_ENCRYPTION_KEY (still
# functional, but operationally cleaner to use a dedicated key so audit
# integrity verification can run on a read-only follower without exposing
# the backup KEK).
# Generate: 32 bytes hex. Distinct from the keys above.
LOG_HMAC_KEY=CHANGE_ME_generate_32_bytes_hex


# ═══════════════════════════════════════════════════════════════════════════════
# 2. SERVER / RUNTIME
# ═══════════════════════════════════════════════════════════════════════════════

# NODE_ENV — 'production', 'development', or 'test'.
# Affects error verbosity, CORS strictness, and a few feature toggles.
# In production, error responses do NOT include stack traces.
# Default: development.
NODE_ENV=production

# PORT — HTTP port the Express server binds to.
# Default: 3000.
PORT=3000

# HOST — bind address.
# 0.0.0.0 listens on all interfaces; 127.0.0.1 listens loopback-only
# (recommended when running behind a reverse proxy on the same host).
# Default: 0.0.0.0.
HOST=0.0.0.0

# TRUST_PROXY — Express trust-proxy setting for X-Forwarded-* header
# handling. Required when FireAlive runs behind a reverse proxy (NGINX,
# Caddy, Cloudflare, AWS ALB, k8s ingress) so req.ip resolves to the
# actual client IP, not the proxy's. Without this, the rate limiter
# buckets every client under the proxy's IP and is effectively
# disabled. Also honored by the GD server.
#
# Accepted values (matching Express semantics):
#   <unset>      — Express default of false; trust no proxy.
#                  Correct for direct internet exposure.
#   loopback     — Trust 127.0.0.1 / ::1 only. Use when the proxy is
#                  on the same host (typical local NGINX/Caddy setup).
#   1            — Trust exactly one hop. Typical single-proxy setup.
#   2            — Trust exactly two hops. E.g. Cloudflare + NGINX.
#   uniquelocal  — Trust all private + loopback IPs. Typical for
#                  Kubernetes ingress controllers.
#
# Setting this too permissively in a deployment WITHOUT a real proxy
# in front lets attackers spoof X-Forwarded-For headers and bypass
# IP-based rate limiting. When in doubt, prefer the most restrictive
# value that matches your topology.
# Default: unset (no proxy trusted).
# TRUST_PROXY=1

# HOSTNAME — used as the source identifier in CEF audit log events
# streamed to your SIEM. Should be distinct per FireAlive instance in
# multi-deployment environments.
# Default: 'firealive' (compliance) or os.hostname() (soar-alerting).
HOSTNAME=firealive-prod-1

# JWT_EXPIRY — JWT lifetime as a duration string (e.g. '15m', '1h', '7d').
# Short expiries reduce the impact of token theft; the refresh-token flow
# in routes/auth.js handles silent renewal.
# Default: '15m'.
JWT_EXPIRY=15m

# FIREALIVE_MASTER_KEY — fallback master key for v054 features.
# If unset, a random 32-byte key is generated on each boot, which means
# v054-encrypted state does not survive restarts. Set this for production.
# Generate: 32 bytes hex.
FIREALIVE_MASTER_KEY=CHANGE_ME_generate_32_bytes_hex


# ═══════════════════════════════════════════════════════════════════════════════
# 3. DATABASE + BACKUP PATHS
# ═══════════════════════════════════════════════════════════════════════════════

# DB_PATH — absolute path to the SQLite database file.
# Parent directory must exist and be writable by the server process.
# Default: <repo>/data/firealive.db (relative to server/db/init.js).
DB_PATH=/var/lib/firealive/firealive.db

# BACKUP_DIR — directory where backup artifacts are written.
# Used as the v2 backup root; each backup creates a subdirectory with
# manifest.json, wrapped-key.bin, and the encrypted archive.
# Default: <repo>/data/backups.
BACKUP_DIR=/var/lib/firealive/backups

# BACKUP_PATH — legacy alias for BACKUP_DIR; v1 code paths still read it.
# Set both to the same value during the v1->v2 migration window.
BACKUP_PATH=/var/lib/firealive/backups

# LOG_PATH — directory where winston log files are written.
# Default: <repo>/data/logs.
LOG_PATH=/var/log/firealive


# ═══════════════════════════════════════════════════════════════════════════════
# 4. BACKUP SCHEDULING AND RETENTION
# ═══════════════════════════════════════════════════════════════════════════════

# BACKUP_SCHEDULE — node-cron expression for the automatic backup job.
# Default: '0 2 * * *' (02:00 UTC daily).
# Examples: '0 */6 * * *' (every 6h), '0 2 * * 0' (Sunday 2am), '*/30 * * * *' (every 30 min).
BACKUP_SCHEDULE=0 2 * * *

# CHAIN_VERIFY_SCHEDULE — node-cron expression for the backup-chain integrity
# verifier. Walks backup_chain checking linkage, hashes, and signatures.
# Default: '0 3 * * *' (03:00 UTC daily, an hour after the default backup).
CHAIN_VERIFY_SCHEDULE=0 3 * * *

# BACKUP_PUSH_RETRY_SCHEDULE — node-cron expression for the cloud-backup
# push retry job. Re-attempts uploads for any backup row marked
# push_status='retry'.
# Default: '*/15 * * * *' (every 15 min).
BACKUP_PUSH_RETRY_SCHEDULE=*/15 * * * *

# BACKUP_RETENTION_DAYS — how many days of backups to keep on disk.
# Older backups are deleted (the chain entry stays as forensic record).
# Default: 90.
BACKUP_RETENTION_DAYS=90


# ═══════════════════════════════════════════════════════════════════════════════
# 5. CORS + CROSS-ORIGIN CLIENT ALLOW-LISTS
# ═══════════════════════════════════════════════════════════════════════════════

# CORS_ORIGIN — comma-separated list of allowed origins for the API.
# In production, set to your frontend hosts. Default development behavior
# allows localhost:* origins.
# Example: 'https://soc.example.com,https://soc-admin.example.com'
CORS_ORIGIN=

# FIREALIVE_AC_ORIGIN — origin of the Analyst Client frontend, used by
# the heartbeat / pseudonym-rotation flows to detect cross-origin requests.
# Example: 'https://analyst.example.com'
FIREALIVE_AC_ORIGIN=

# FIREALIVE_MC_ORIGIN — origin of the Management Console frontend.
# Example: 'https://mc.example.com'
FIREALIVE_MC_ORIGIN=

# FIREALIVE_GD_ORIGIN — origin of the Global Dashboard frontend.
# Example: 'https://gd.example.com'
FIREALIVE_GD_ORIGIN=

# GD_ALLOWED_HOSTS — comma-separated allow-list of management-console
# hostnames that the GD-Server will accept registrations from. The MC
# pushes its hostname during registration; if not in this list, register
# is rejected. Multi-tenant deployments use this to scope GD visibility.
GD_ALLOWED_HOSTS=

# HR_ALLOWED_HOSTS — comma-separated allow-list of hostnames permitted
# to push HR-system events into the FireAlive scheduling integration
# (R3c). Empty means HR push is disabled.
HR_ALLOWED_HOSTS=

# EXTERNAL_RESTORE_ALLOWED_HOSTS — comma-separated allow-list of
# hostnames the v054 external-restore endpoint will accept inbound
# pushes from. Empty means external restore is disabled.
EXTERNAL_RESTORE_ALLOWED_HOSTS=


# ═══════════════════════════════════════════════════════════════════════════════
# 6. LOGGING
# ═══════════════════════════════════════════════════════════════════════════════

# LOG_LEVEL — winston log level: 'error', 'warn', 'info', 'http', 'verbose',
# 'debug', 'silly'. Default: 'info'.
LOG_LEVEL=info


# ═══════════════════════════════════════════════════════════════════════════════
# 7. SIEM STREAMING (optional)
# ═══════════════════════════════════════════════════════════════════════════════
#
# Streams CEF-formatted audit_log events to an external SIEM via syslog.
# Leave SIEM_ENABLED unset or 'false' to disable.

# SIEM_ENABLED — 'true' to stream, anything else to disable.
SIEM_ENABLED=false

# SIEM_PROTOCOL — 'udp' or 'tcp'. UDP is unreliable but faster; TCP is
# reliable but blocks on network issues. Default: 'udp'.
SIEM_PROTOCOL=udp

# SIEM_HOST — hostname or IP of the SIEM syslog receiver.
SIEM_HOST=siem.example.com

# SIEM_PORT — syslog port. Default: 514.
SIEM_PORT=514

# SIEM_FACILITY — syslog facility number 0-23. 16-23 are local0-local7,
# the conventional choice for application logs. Default: 16 (local0).
SIEM_FACILITY=16


# ═══════════════════════════════════════════════════════════════════════════════
# 8. SMTP (optional)
# ═══════════════════════════════════════════════════════════════════════════════
#
# Used by the notifications service to send burnout-alert and approval-
# queue digest emails. Leave SMTP_HOST unset to disable email entirely;
# in-app notifications and SIEM events still work.

# SMTP_HOST — SMTP server hostname.
SMTP_HOST=

# SMTP_PORT — SMTP port. Common values: 587 (STARTTLS), 465 (TLS), 25 (none).
SMTP_PORT=587

# SMTP_SECURE — 'true' for implicit TLS (port 465), 'false' for STARTTLS or
# plaintext (ports 587, 25).
SMTP_SECURE=false

# SMTP_USER — SMTP auth username.
SMTP_USER=

# SMTP_PASS — SMTP auth password. Sensitive -- never commit a real value.
SMTP_PASS=

# SMTP_FROM — From-address for outgoing notifications.
SMTP_FROM=firealive@example.com

# NOTIFICATIONS_EMAIL_INTERVAL_SEC — minimum seconds between batched
# email digests to prevent flooding admins. Default: 300 (5 minutes).
NOTIFICATIONS_EMAIL_INTERVAL_SEC=300


# ═══════════════════════════════════════════════════════════════════════════════
# 9. LOCAL LLM (optional, for AI-assisted features)
# ═══════════════════════════════════════════════════════════════════════════════
#
# FireAlive can run a local-only LLM for SOC analyst guidance and IR
# scenario generation. Privacy-first: no analyst data leaves the
# machine. Requires a GGUF model file on disk and node-llama-cpp.

# FIREALIVE_MODEL_PATH — absolute path to a GGUF model file.
# Recommended: a 7B-13B parameter Llama or Mistral variant in Q4_K_M
# quantization (~4-7GB).
FIREALIVE_MODEL_PATH=/var/lib/firealive/models/llama-7b-q4.gguf

# FIREALIVE_LLM_IDLE_UNLOAD_MS — idle time before unloading the model
# from RAM to free memory. Default: 600000 (10 min).
FIREALIVE_LLM_IDLE_UNLOAD_MS=600000


# ═══════════════════════════════════════════════════════════════════════════════
# 10. OODA SCHEDULED MODE (optional)
# ═══════════════════════════════════════════════════════════════════════════════
#
# The OODA Loop simulator can pre-generate IR scenarios in the background
# so analysts always have fresh content available. These tune the
# scheduled-generation worker.

# OODA_JOB_CONCURRENCY — max simultaneous LLM generation jobs.
# Default: 1 (single-threaded; LLM is CPU/RAM-bound).
OODA_JOB_CONCURRENCY=1

# OODA_JOB_TICK_MS — how often the scheduler checks for queued jobs.
# Default: 5000 (5s).
OODA_JOB_TICK_MS=5000

# OODA_JOB_TIMEOUT_MS — kill jobs running longer than this.
# Default: 600000 (10 min).
OODA_JOB_TIMEOUT_MS=600000


# ═══════════════════════════════════════════════════════════════════════════════
# 11. HASHICORP VAULT (optional, only if using Vault key-wrapping provider)
# ═══════════════════════════════════════════════════════════════════════════════

# VAULT_REQUEST_TIMEOUT_MS — timeout for Vault transit-engine wrap/unwrap
# calls. Default: 5000 (5s). Increase for high-latency networks.
VAULT_REQUEST_TIMEOUT_MS=5000


# ═══════════════════════════════════════════════════════════════════════════════
# 12. DIAGNOSTIC / ADVANCED (use with care)
# ═══════════════════════════════════════════════════════════════════════════════

# SKIP_INTEGRITY_CHECK — if set to 'true', bypasses the boot-time
# integrity check that verifies the database hasn't been tampered with
# since last shutdown. NEVER set this in production. Intended only for
# disaster-recovery scenarios where you have manually verified integrity
# out of band.
# SKIP_INTEGRITY_CHECK=false


# ═══════════════════════════════════════════════════════════════════════════════
# Quick deployment checklist
# ═══════════════════════════════════════════════════════════════════════════════
#
# Before first start of a production deployment:
#
#   [ ] Generate JWT_SECRET, TIER1_ENCRYPTION_KEY, TIER3_ENCRYPTION_KEY,
#       LOG_HMAC_KEY, FIREALIVE_MASTER_KEY (each 32 bytes hex, distinct)
#   [ ] Set NODE_ENV=production
#   [ ] Set DB_PATH, BACKUP_DIR, LOG_PATH to writable locations OUTSIDE
#       the repo (so updates don't risk overwriting them)
#   [ ] Configure CORS_ORIGIN for your frontend hosts
#   [ ] Set FIREALIVE_*_ORIGIN for the three frontends
#   [ ] Set HOSTNAME to a unique, recognizable value
#   [ ] Choose a BACKUP_SCHEDULE that fits your operational cadence
#   [ ] If using SMTP: SMTP_HOST/PORT/USER/PASS/FROM
#   [ ] If using SIEM: SIEM_ENABLED=true + SIEM_HOST/PORT/PROTOCOL
#   [ ] Verify file permissions: .env should be chmod 0600, owned by the
#       service account, and NEVER world-readable
#   [ ] Verify .env is in .gitignore
#   [ ] After first start, enroll TOTP for every admin account:
#       POST /api/mfa/enroll-start, scan QR, POST /api/mfa/enroll-confirm
#   [ ] Set restore_approval_mode in system_meta:
#       UPDATE system_meta SET value='strict' WHERE key='restore_approval_mode';
#       (see docs/two-person-restore.md for mode tradeoffs)
#
# ═══════════════════════════════════════════════════════════════════════════════
